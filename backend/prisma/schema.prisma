generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  senha     String
  nome      String
  role      String   @default("GERENTE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("usuarios")
}

model Cliente {
  id        String   @id @default(uuid())
  nome      String
  email     String?
  telefone  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  anotacao  String?

  @@map("clientes")
}

model Venda {
  id        String      @id @default(uuid())
  numero    Int         @unique @default(autoincrement())
  cliente   String
  data      DateTime    @default(now())
  total     Decimal     @db.Decimal(10, 2)
  status    String      @default("Concluída")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  itens     ItemVenda[]

  @@map("vendas")
}

model ItemVenda {
  id         String  @id @default(uuid())
  vendaId    String  @map("venda_id")
  quantidade Int
  precoUnit  Decimal @map("preco_unit") @db.Decimal(10, 2)
  item_id    String
  itens      itens   @relation(fields: [item_id], references: [id])
  venda      Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@map("itens_venda")
}

model itens {
  id                  String                @id @default(uuid())
  is_produto          Boolean               @default(false)
  is_insumo           Boolean               @default(false)
  nome                String
  tipo                String
  quantidade          Int                   @default(0)
  alerta_minimo       Int                   @default(0)
  created_at          DateTime              @default(now())
  updated_at          DateTime              @default(now()) @updatedAt
  material            String?               @default("—")
  preco               Decimal?              @db.Decimal(10, 2)
  unidade             String?
  descricao           String?
  preco_custo         Decimal?              @db.Decimal(10, 2)
  fornecedor          String?
  itens_venda         ItemVenda[]
  movimentacoes_itens movimentacoes_itens[]
}

model movimentacoes_itens {
  id         String           @id @default(uuid())
  item_id    String
  tipo       TipoMovimentacao
  quantidade Int
  motivo     String?
  created_at DateTime         @default(now())
  itens      itens            @relation(fields: [item_id], references: [id], onDelete: Cascade)
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
}
